# Quit bspwm
super + shift + Escape
  bspc quit

# Restart bspwm
super + r
  bspc wm -r

# Open power menu
super + p
  ~/.scripts/powermenu.sh

# lockscreen
alt + shift + x
  betterlockscreen -l blur

# Terminal emulator
super + Return
  alacritty

# Kill window
super + shift + q
  bspc node -c

# Switch to desktop
super + {1-9, 0}
  bspc desktop -f {1-9, 10}

# Focus on window in direction
super + {h,j,k,l}
  bspc node -f {west,south,north,east}

# Send window to desktop
super + shift + {1-9, 0}
  bspc node -d {1-9, 10}

# Send window to desktop and swap to desktop
super + control + {1-9, 0}
  bspc node -d {1-9, 10} && bspc desktop -f {1-9, 10}

# Toggle fullscreen
super + f
  bspc node focused.fullscreen -t tiled || bspc node focused.tiled -t fullscreen

# Make window floating
super + shift + space
  bspc node -t ~floating

# Move floating window
super + {Left,Down,Up,Right}
  bspc node -v {-20 0,0 20,0 -20,20 0}

# Expand floating window
super + ctrl + {Left,Down,Up,Right}
  bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# Contract floating window
super + shift + ctrl + {Left,Down,Up,Right}
  bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# Expand a window from a direction
ctrl + alt + {h,j,k,l}
  bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# Contract a window from a direction
ctrl + alt + shift + {h,j,k,l}
  bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# Swap window with direction
super + shift + {h,j,k,l}
  bspc node -s {west,south,north,east}

# Preselect window direction
super + ctrl + {h,j,k,l}
  bspc node -p {west,south,north,east}

# Swap node with biggest node
super + g
  bspc node -s biggest.window

# Swap node with smallest node
super + s
  bspc node -s smallest.window

# Application launcher
super + d
  rofi -show drun

# Quick window switch
super + w
  rofi -show window

# Screen brightness
XF86MonBrightness{Up,Down}
  xbacklight {-inc,-dec} 5

# Audio
XF86Audio{Raise,Lower}Volume
  amixer sset Master 5%{+,-}

XF86AudioMute
  amixer sset Master toggle
